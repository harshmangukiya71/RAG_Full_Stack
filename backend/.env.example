MEMORY_MAX_TURNS=4

CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_ENTRIES=512
SEMANTIC_CACHE_THRESHOLD=0.92

CORS_ORIGINS=[]
