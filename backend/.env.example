NVIDIA_TEMPERATURE=0.1

NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
NVIDIA_EMBEDDING_BATCH_SIZE=64

NEO4J_URI=neo4j+s://your-aura-host.databases.neo4j.io
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
GRAPH_BACKEND=neo4j

VECTOR_DB=pinecone
PINECONE_API_KEY=
PINECONE_HOST=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=default
COLLECTION_NAME=legal_docs

CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
MIN_NATIVE_CHARS_PER_PAGE=40
OCR_RENDER_DPI=220

BM25_TOP_K=20
DENSE_TOP_K=20
GRAPH_TOP_K=12
GRAPH_BOOST_WEIGHT=0.12
RERANK_TOP_K=5
FINAL_CONTEXT_K=5

MIN_RELEVANCE_SCORE=0.05
MIN_ANSWER_COVERAGE=0.20
CONFIDENCE_SCALE_FACTOR=1.6

MEMORY_BACKEND=auto
REDIS_URL=
